---
// Homepage - to be implemented in Step 2.1
import Layout from '@layouts/Layout.astro';
import ProductCard from '@components/catalog/ProductCard.astro';
import CategoryCard from '@components/catalog/CategoryCard.astro';
import MediaMentions from '@components/trust/MediaMentions.astro';
import ThirdPartyReviews from '@components/trust/ThirdPartyReviews.astro';
import BrandHero from '@components/brands/BrandHero.astro';
import BrandHomePage from '@components/brands/BrandHomePage.astro';
import { fetchSiteConfig } from '@lib/site-config';

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'DTC Store';

const siteConfig = await fetchSiteConfig(Astro.request);
const brand = siteConfig?.brand;
if (!brand) {
  return new Response('Site not found', { status: 404 });
}

const apiOrigin = new URL(Astro.request.url).origin;

const [featuredData, categoriesData] = await Promise.all([
  fetch(new URL('/api/products/list', apiOrigin).toString(), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'x-brand-id': brand.id },
    body: JSON.stringify({ featured: true, limit: 8, sort: 'featured' }),
  })
    .then((r) => r.json())
    .catch(() => null),
  fetch(new URL('/api/categories', apiOrigin).toString(), {
    headers: { 'x-brand-id': brand.id },
  })
    .then((r) => r.json())
    .catch(() => null),
]);

const featuredProducts = featuredData?.products || [];
const categories = categoriesData?.categories || [];
---

<Layout title="Home" description={`Shop curated products at ${brand.name || siteName}.`}> 
  <main>
    <!-- 品牌专属 Hero 组件（根据 brand.slug 动态加载） -->
    <BrandHero brand={brand} />

    <!-- 品牌专属首页内容（根据 brand.slug 动态加载） -->
    <BrandHomePage brand={brand} products={featuredProducts} categories={categories} />
  </main>
</Layout>
