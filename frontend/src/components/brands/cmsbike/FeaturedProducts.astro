---
/**
 * CMSBike 明星产品展示
 * 4款主推产品卡片
 */
interface Props {
  brand?: any;
  products?: any[];
}

const { brand, products = [] } = Astro.props;

const R2_BASE = 'https://assets.cmsbike.uk';

// 如果没有从 API 获取到产品，使用默认数据
const featuredModels = [
  {
    sku: 'CMS-6-14D',
    name: '14" Urban Essential',
    tagline: 'Entry-level city commuter',
    price: 495,
    originalPrice: null,
    image: `${R2_BASE}/14-inch/black-side.jpg`,
    features: ['Single Speed', 'Disc Brakes', '15kg'],
    badge: 'Best Value',
    href: '/products/cms-6-14d'
  },
  {
    sku: 'CMS-16NB',
    name: '16" Premium Classic',
    tagline: 'Shimano Nexus internal hub',
    price: 899,
    originalPrice: null,
    image: `${R2_BASE}/14-inch/gray-side.jpg`,
    features: ['Nexus 3-Speed', 'Brown Leather', 'CST Tires'],
    badge: 'Best Seller',
    badgeColor: 'orange',
    href: '/products/cms-16nb'
  },
  {
    sku: 'CMSTD-6-14D',
    name: '14" City Electric',
    tagline: 'Compact e-bike power',
    price: 999,
    originalPrice: null,
    image: `${R2_BASE}/ebike-16/product-hero.jpg`,
    features: ['250W Motor', '30-40km Range', 'LED Light'],
    badge: 'Electric',
    badgeColor: 'blue',
    href: '/products/cmstd-6-14d'
  },
  {
    sku: 'CMSTD-6-16D',
    name: '16" Power Commuter',
    tagline: 'BAFANG motor + Samsung battery',
    price: 1290,
    originalPrice: null,
    image: `${R2_BASE}/ebike-16/hero-folding.jpg`,
    features: ['BAFANG 250W', 'Samsung/LG Battery', '50km Range'],
    badge: 'Top Tier',
    badgeColor: 'purple',
    href: '/products/cmstd-6-16d'
  }
];

const displayProducts = products.length > 0 ? products : featuredModels;
---

<section class="py-20 bg-white">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-12">
      <div>
        <span class="inline-block px-4 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium mb-4">
          Our Bikes
        </span>
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">
          Featured Models
        </h2>
        <p class="mt-3 text-lg text-gray-600">
          From budget-friendly to premium electric
        </p>
      </div>
      <a href="/products" class="inline-flex items-center gap-2 text-orange-600 hover:text-orange-700 font-medium">
        View all bikes
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {displayProducts.map((product) => (
        <a 
          href={product.href || `/products/${product.slug || product.sku?.toLowerCase()}`}
          class="group bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-xl hover:border-orange-200 transition-all duration-300"
        >
          {/* Image */}
          <div class="relative aspect-square bg-gray-50 overflow-hidden">
            {product.image || product.images?.[0] ? (
              <img 
                src={product.image || product.images?.[0]}
                alt={product.name}
                class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
                <div class="text-center text-gray-400">
                  <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span class="text-xs">Coming Soon</span>
                </div>
              </div>
            )}

            {/* Badge */}
            {product.badge && (
              <div class="absolute top-3 left-3">
                <span class={`px-3 py-1 rounded-full text-xs font-bold text-white ${
                  product.badgeColor === 'orange' ? 'bg-orange-500' :
                  product.badgeColor === 'blue' ? 'bg-blue-500' :
                  product.badgeColor === 'purple' ? 'bg-purple-500' :
                  'bg-green-500'
                }`}>
                  {product.badge}
                </span>
              </div>
            )}
          </div>

          {/* Content */}
          <div class="p-5">
            <div class="text-xs text-gray-500 mb-1">{product.sku}</div>
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-orange-600 transition-colors">
              {product.name}
            </h3>
            <p class="text-sm text-gray-600 mt-1 line-clamp-1">{product.tagline || product.description}</p>

            {/* Features */}
            {product.features && (
              <div class="flex flex-wrap gap-1 mt-3">
                {product.features.slice(0, 3).map((f: string) => (
                  <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs">
                    {f}
                  </span>
                ))}
              </div>
            )}

            {/* Price */}
            <div class="mt-4 flex items-center gap-2">
              <span class="text-xl font-bold text-gray-900">
                ${product.price?.toLocaleString()}
              </span>
              {product.originalPrice && (
                <span class="text-sm text-gray-400 line-through">
                  ${product.originalPrice?.toLocaleString()}
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
